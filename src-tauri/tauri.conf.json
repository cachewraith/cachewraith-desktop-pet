{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CacheWraith",
  "version": "0.1.2",
  "identifier": "com.cachewraith.desktoppet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "CacheWraith",
        "width": 280,
        "height": 320,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "CacheWraith Settings",
        "width": 820,
        "height": 680,
        "minWidth": 640,
        "minHeight": 500,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "CacheWraith",
    "category": "Utility",
    "shortDescription": "A friendly animated desktop ghost pet",
    "longDescription": "CacheWraith is a lightweight animated AI desktop pet that lives near your taskbar. It idles, walks, sleeps and chats with you, with optional OpenAI-powered conversations.",
    "copyright": "Copyright (c) 2026 CacheWraith contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
